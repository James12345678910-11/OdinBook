<h1>My Posts</h1>

<%= link_to 'New Post', new_post_path %>

<ul>
  <% @suggested_users.each do |user| %>
    <li>
      <%= link_to user.name, user_path(user) %>
    </li>
  <% end %>

  <div class="posts-feed">
  <% @posts.each do |post| %>
    <div class="post-card">
      <%= link_to post_path(post), class: "post-link" do %>
        <h3><%= post.user&.name %></h3>
        <p><%= post.content %></p>
      <% end %>
      <% if post.user == current_user %>
        <div class="post-actions">
          <%= link_to 'Edit', edit_post_path(post), class: "btn btn-secondary" %>
          <%= button_to 'Delete', post_path(post), method: :delete, class: "btn btn-danger", data: { turbo_confirm: "Are you sure?" } %>
        </div>
      <% end %>
    </div>
  <% end %>
</div>
</ul>

  